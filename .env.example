# MCSR Ranked Bedrock — example environment variables
# Copy to .env for local development. .env is gitignored.

MCSR_ENV=dev

# HTTP listener for the queen service
MCSR_HTTP_ADDR=:8080

# SQLite database file (Phase 0; will move to PostgreSQL-ready schema later)
MCSR_DB_PATH=data/queen.db

# Resources directory; relative paths are anchored at the binary's location
MCSR_RESOURCES_DIR=resources
MCSR_SEEDS_MANIFEST=resources/seeds/manifest.json

# Match timeout (Go duration syntax: "30m", "1h", etc.)
MCSR_GAME_TIMEOUT=30m

# Logging
MCSR_LOG_LEVEL=info
MCSR_LOG_FORMAT=text
